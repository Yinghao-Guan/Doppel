# Copy to .env.local and fill in. Never commit .env.local.

# ─── Server-side (production-only paid keys) ─────────────────────────────────
# Used by: frontend/src/lib/gemini.ts (Gemini calls in /api/coach/*).
GEMINI_API_KEY=

# Optional override for the Gemini host / model.
# GEMINI_HOST=https://generativelanguage.googleapis.com
# GEMINI_MODEL=gemini-2.5-flash

# Voice coaching (only required when /api/voice is wired up).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Public client-side (baked into the JS bundle) ───────────────────────────
# Used by: frontend/src/lib/solana.ts (BACKEND_URL).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Used by: frontend/src/components/WalletProvider.tsx (Solana RPC endpoint).
# Defaults to clusterApiUrl('devnet') if unset, but the public Solana RPC has
# tight rate limits — set this to a Helius / QuickNode URL for production.
NEXT_PUBLIC_SOLANA_RPC_URL=
