# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit secrets.

# ─── Gemini (AI coach) ─────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional. Defaults to "gemini-2.5-flash" if unset.
GEMINI_MODEL=

# ─── ElevenLabs (voice coaching) ───────────────────────────────────────────
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional. Defaults to "Rachel" (21m00Tcm4TlvDq8ikWAM).
# For an athletic male coach try "Adam" (IKne3meq5aSn9XLyUdCD).
ELEVENLABS_VOICE_ID=
